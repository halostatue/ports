                    size    3087155

post-build {
    set prqlc "target/[cargo.rust_platform]/release/prqlc"
    system -W ${worksrcpath} "${prqlc} shell-completion bash > prqlc.bash"
    system -W ${worksrcpath} "${prqlc} shell-completion fish > prqlc.fish"
    system -W ${worksrcpath} "${prqlc} shell-completion zsh > prqlc.zsh"
}

destroot {
    xinstall -m 0755 \
        "${worksrcpath}/target/[cargo.rust_platform]/release/prqlc" \
        "${destroot}${prefix}/bin/"

    set bash_completions_dir share/bash-completion/completions
    xinstall -d ${destroot}${prefix}/${bash_completions_dir}
    xinstall -m 0644 ${worksrcpath}/prqlc.bash \
        ${destroot}${prefix}/${bash_completions_dir}/prqlc

    set fish_completions_dir share/fish/vendor_completions.d
    xinstall -d ${destroot}${prefix}/${fish_completions_dir}
    xinstall -m 0644 ${worksrcpath}/prqlc.fish \
        ${destroot}${prefix}/${fish_completions_dir}

    set zsh_completions_dir share/zsh/site-functions
    xinstall -d ${destroot}${prefix}/${zsh_completions_dir}
    xinstall -m 0644 ${worksrcpath}/prqlc.zsh \
        ${destroot}${prefix}/${zsh_completions_dir}/_prqlc
}

